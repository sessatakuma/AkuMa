{
    "manifest_version": 3,
    "name": "AkuMa Furigana",
    "description": "Add Japanese furigana and pitch accent annotations to pages.",
    "action": {
        "default_popup": "page.html",
        "default_title": "AkuMa"
    },
    "permissions": [
        "activeTab",
        "identity",
        "storage",
        "scripting"
    ],
    "icons": {
        "64": "assets/logo-64.png",
        "128": "assets/logo-128.png"
    }
}
