{
    "manifest_version": 3,
    "name": "AkuMa Furigana",
    "description": "Add Japanese furigana and pitch accent annotations to pages.",
    "action": {
        "default_title": "AkuMa"
    },
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "64": "assets/logo-64.png",
        "128": "assets/logo-128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "content.css"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "run_at": "document_idle",
            "css": [
                "content.css"
            ],
            "js": [
                "config.js",
                "accent-types.js",
                "accent-mappers.js",
                "annotation-renderer.js",
                "api.js",
                "content.js"
            ]
        }
    ]
}
