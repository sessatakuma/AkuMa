# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_ENV=

# Supabase Auth
# Public values are safe for browser and extension builds.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# Server-only Supabase key. Prefer SUPABASE_SECRET_KEY when available.
SUPABASE_SECRET_KEY=your_supabase_secret_key
# SUPABASE_SERVICE_ROLE_KEY=your_legacy_supabase_service_role_key

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_pro_price_id
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_49_usd_annual_pro_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Mark accent upstream proxy
MARK_ACCENT_API_KEY=your_mark_accent_api_key
# MARK_ACCENT_UPSTREAM_URL=https://api.sessatakuma.dev/v1/mark-accent

# Chrome extension API access
# Comma-separate extension origins after Chrome assigns IDs.
# Example: chrome-extension://abcdefghijklmnopabcdefghijklmnop
AKUMA_EXTENSION_ORIGINS=

# CRX build-time config
# Defaults to production Akuma URL when omitted.
# AKUMA_CRX_API_BASE_URL=https://akuma.sessatakuma.dev
# AKUMA_CRX_APP_URL=https://akuma.sessatakuma.dev
